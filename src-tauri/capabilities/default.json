{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the Ardor Solutions desktop prototype.",
  "webviews": ["main", "offscreen-browser-gpu-shell-*"],
  "permissions": [
    "core:default",
    "process:allow-restart",
    "allow-check-desktop-update",
    "allow-close-sidebar-browser",
    "allow-complete-auth-callback",
    "allow-control-sidebar-browser",
    "allow-get-auth-callback-status",
    "allow-get-pending-auth-callback",
    "allow-input-sidebar-browser",
    "allow-install-desktop-update",
    "allow-layout-sidebar-browser",
    "allow-open-auth-url",
    "allow-open-sidebar-browser"
  ]
}
