{
  "name": "@ardor/desktop",
  "private": true,
  "version": "0.3.7",
  "type": "module",
  "scripts": {
    "ui:dev": "bun run ui:dev:stage1",
    "ui:dev:stage1": "bun scripts/run-ui.mjs stage1 dev",
    "ui:build": "bun run ui:build:stage1",
    "ui:build:stage1": "bun scripts/run-ui.mjs stage1 build",
    "ui:build:prod": "bun scripts/run-ui.mjs prod build",
    "ui:type-check": "bun scripts/run-ui.mjs stage1 type-check",
    "tauri:install-cef-cli": "cargo install tauri-cli --git https://github.com/tauri-apps/tauri --rev 9851021fae837e6fa0316577f01f10f59143695b --locked",
    "tauri:dev": "bun scripts/run-tauri.mjs dev default",
    "tauri:dev:stage1": "bun scripts/run-tauri.mjs dev stage1",
    "tauri:build": "bun scripts/run-tauri.mjs build default",
    "tauri:build:stage1": "bun scripts/run-tauri.mjs build stage1",
    "tauri:build:prod": "bun scripts/run-tauri.mjs build prod",
    "tauri:build:stage1:nsis": "bun run tauri:build:stage1 -- --bundles nsis",
    "tauri:build:prod:nsis": "bun run tauri:build:prod -- --bundles nsis",
    "build:stage1:nsis": "bun run ui:type-check && bun run tauri:build:stage1:nsis",
    "build:prod:nsis": "bun run ui:type-check && bun run tauri:build:prod:nsis",
    "build:windows:stage1": "bun scripts/build-windows-installer.mjs --channel stage1",
    "build:windows:prod": "bun scripts/build-windows-installer.mjs --channel prod",
    "windows:installer": "bun scripts/build-windows-installer.mjs --channel stage1",
    "windows:installer:stage1": "bun scripts/build-windows-installer.mjs --channel stage1",
    "windows:installer:prod": "bun scripts/build-windows-installer.mjs --channel prod",
    "windows:prepare-bootstrap": "node scripts/prepare-windows-bootstrap.mjs",
    "build": "bun run build:stage1",
    "build:stage1": "bun run ui:type-check && bun run tauri:build:stage1 -- --bundles app",
    "build:prod": "bun run ui:type-check && bun run tauri:build:prod -- --bundles app",
    "test:release-security": "node --test scripts/release-security.test.mjs",
    "test:cef-build-env": "node --test scripts/cef-build-env.test.mjs",
    "test:macos-metal-contract": "node --test scripts/macos-metal-contract.test.mjs",
    "test:ui-contract": "node --test scripts/verify-desktop-ui-contract.test.mjs",
    "verify:ui-contract": "node scripts/verify-desktop-ui-contract.mjs",
    "test:update-manifest": "node --test scripts/generate-update-manifest.test.mjs",
    "sync-version": "bun scripts/sync-version.mjs",
    "release": "node ./node_modules/semantic-release/bin/semantic-release.js",
    "commit": "bunx --bun git-cz"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "semantic-release": "^25.0.6"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
