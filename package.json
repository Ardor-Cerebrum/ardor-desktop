{
  "name": "@ardor/desktop",
  "private": true,
  "version": "0.2.7",
  "type": "module",
  "scripts": {
    "ui:dev": "bun run ui:dev:stage1",
    "ui:dev:stage1": "bun scripts/run-ui.mjs stage1 dev",
    "ui:build": "bun run ui:build:stage1",
    "ui:build:stage1": "bun scripts/run-ui.mjs stage1 build",
    "ui:build:prod": "bun scripts/run-ui.mjs prod build",
    "ui:type-check": "cd ../solutions-ui && bun run type-check",
    "tauri:dev": "bunx --bun @tauri-apps/cli@2.11.2 dev",
    "tauri:dev:stage1": "bunx --bun @tauri-apps/cli@2.11.2 dev --config src-tauri/tauri.stage1.conf.json",
    "tauri:build": "bunx --bun @tauri-apps/cli@2.11.2 build",
    "tauri:build:stage1": "bunx --bun @tauri-apps/cli@2.11.2 build --config src-tauri/tauri.stage1.conf.json",
    "tauri:build:prod": "bunx --bun @tauri-apps/cli@2.11.2 build --config src-tauri/tauri.prod.conf.json",
    "build": "bun run build:stage1",
    "build:stage1": "bun run ui:type-check && bun run tauri:build:stage1 -- --bundles app",
    "build:prod": "bun run ui:type-check && bun run tauri:build:prod -- --bundles app",
    "sync-version": "bun scripts/sync-version.mjs",
    "release": "bunx --bun semantic-release",
    "commit": "bunx --bun git-cz"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@tauri-apps/cli": "2.11.2",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "semantic-release": "^24.2.7"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
